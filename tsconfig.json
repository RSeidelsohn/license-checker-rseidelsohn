{
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "dist",
		"allowJs": true,
		"allowImportingTsExtensions": true
	},
	"include": ["bin/**/*", "lib/**/*", "scripts/**/*", "test/**/*"]
}
